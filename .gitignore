# NEVER commit — contains the Anthropic API key.
.env
.env.*
!.env.example

# Local Python artefacts
__pycache__/
*.pyc
.venv/
venv/

# Playwright browsers, if they ever land back in this folder
.browsers/

# Working files, regenerated on every run. store.json IS committed on purpose —
# it's the accumulated analysis and re-creating it costs real money.
updates.json
browser_updates.json
*.tmp
store.json.bak

# Health check output. Not committed on purpose: both carry a timestamp that
# changes every run, so committing them would produce a daily commit even on
# days with no new agency items — and the workflow's "nothing to publish" check
# would never be true again. In CI these are kept as run artifacts instead.
fetch_report.json
health.json

# wrangler local cache — contains account id/name, not for a public repo
worker/.wrangler/

# Derived calendar feed, regenerated every build (see dashboard.py ICS_PATH)
deadlines.ics
